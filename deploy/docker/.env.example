# =====================================
# Database / 数据库
# =====================================
MYSQL_DATABASE=bytedesk
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=please_change_mysql_password
MYSQL_PORT=3306
MYSQL_HOST_PORT=13306

POSTGRES_DB=bytedesk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=please_change_postgres_password
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=15432

KINGBASE_IMAGE=kingbase_v009r001c010b0004_single_arm:v1
KINGBASE_DATABASE=bytedesk
KINGBASE_DB_USER=root
KINGBASE_DB_PASSWORD=please_change_kingbase_password
KINGBASE_SYSTEM_PWD=SYSTEM
KINGBASE_PORT=54321
KINGBASE_HOST_PORT=54321
KINGBASE_LICENSE_FILE=../kingbase/license_V009R001C-专业版.dat
# 可选值：mysql | postgresql | oracle | sqlserver（默认 mysql）
KINGBASE_DB_MODE=mysql
KINGBASE_ENABLE_CI=yes
KINGBASE_NEED_START=yes

FREESWITCH_DB_HOST=bytedesk-db
FREESWITCH_DATABASE=bytedesk_freeswitch

# =====================================
# Middleware Credentials / 中间件凭据
# =====================================
REDIS_PASSWORD=please_change_redis_password
ELASTIC_PASSWORD=please_change_elasticsearch_password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=please_change_minio_password

# =====================================
# Message Queue / 消息队列
# =====================================
ARTEMIS_USER=admin
ARTEMIS_PASSWORD=please_change_artemis_password

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=please_change_rabbitmq_password

# =====================================
# Oracle (optional) / Oracle（可选）
# =====================================
ORACLE_DATABASE=bytedesk
ORACLE_PASSWORD=please_change_oracle_sys_password
ORACLE_APP_USER=bytedesk
ORACLE_APP_USER_PASSWORD=please_change_oracle_app_password

# =====================================
# Call scenario / 呼叫中心场景
# =====================================
COTURN_REALM=bytedesk.local
COTURN_USER=bytedesk
COTURN_PASS=please_change_coturn_password
FREESWITCH_ESL_PASSWORD=please_change_freeswitch_esl_password

# FreeSWITCH runtime overrides / FreeSWITCH 运行参数覆盖
# 说明：以下变量会覆盖 deploy/freeswitch/conf/vars.xml 中默认值
# XML-CURL 回源地址请填写“freeswitch 容器可访问”的应用地址
FREESWITCH_CDR_PASSWORD=please_change_freeswitch_cdr_password
FREESWITCH_XML_CURL_TOKEN=please_change_xml_curl_token
FREESWITCH_XML_CURL_GATEWAY_URL=http://bytedesk-starter:9003/freeswitch/api/v1/xmlcurl
FREESWITCH_API_BASE_URL=http://bytedesk-starter:9003
FREESWITCH_DB_HOST=bytedesk-db
FREESWITCH_DB_PORT=3306
FREESWITCH_DB_NAME=bytedesk_freeswitch
FREESWITCH_DB_USERNAME=root
FREESWITCH_DB_PASSWORD=please_change_freeswitch_db_password
# 推荐：在 docker 网络内使用 coturn 服务名
FREESWITCH_STUN_SERVER=stun:bytedesk-coturn:3478
FREESWITCH_RTP_START_PORT=16384
FREESWITCH_RTP_END_PORT=32768

# =====================================
# Bytedesk security / 微语安全配置
# =====================================
BYTEDESK_LICENSE_KEY=
BYTEDESK_ADMIN_PASSWORD=please_change_admin_password
BYTEDESK_ADMIN_VALIDATE_CODE=please_change_admin_validate_code
BYTEDESK_MEMBER_PASSWORD=please_change_member_password
BYTEDESK_JWT_SECRET_KEY=please_change_jwt_secret_key

# =====================================
# AI provider API keys (optional) / AI 提供商密钥（可选）
# =====================================
SPRING_AI_ZHIPUAI_API_KEY=
SPRING_AI_DEEPSEEK_API_KEY=
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_DASHSCOPE_API_KEY=
SPRING_AI_DASHSCOPE_AUDIO_TRANSCRIPTION_API_KEY=
SPRING_AI_SILICONFLOW_API_KEY=
SPRING_AI_GITEE_API_KEY=
SPRING_AI_TENCENT_API_KEY=
SPRING_AI_BAIDU_API_KEY=
SPRING_AI_VOLCENGINE_API_KEY=

# =====================================
# Optional third-party config / 可选三方配置
# =====================================
BYTEDESK_TRANSLATE_BAIDU_APPID=
BYTEDESK_TRANSLATE_BAIDU_KEY=

# Optional: provide this only when using ENC(...) values with Jasypt
JASYPT_ENCRYPTOR_PASSWORD=
