    <!-- bytedesk_ai_prompt -->
    <changeSet id="260305-migrate-ai-prompt-variables-json-to-text" author="jackning">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <dbms type="mysql,mariadb"/>
            <tableExists tableName="bytedesk_ai_prompt"/>
            <columnExists tableName="bytedesk_ai_prompt" columnName="variables"/>
            <sqlCheck expectedResult="1"><![CDATA[
                SELECT CASE WHEN EXISTS (
                    SELECT 1
                    FROM information_schema.columns
                    WHERE table_schema = DATABASE()
                      AND table_name = 'bytedesk_ai_prompt'
                      AND column_name = 'variables'
                      AND data_type = 'json'
                ) THEN 1 ELSE 0 END
            ]]></sqlCheck>
        </preConditions>

        <modifyDataType tableName="bytedesk_ai_prompt" columnName="variables" newDataType="TEXT"/>

        <rollback>
            <modifyDataType tableName="bytedesk_ai_prompt" columnName="variables" newDataType="JSON"/>
        </rollback>
    </changeSet>

