<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- 添加 show_message_status 字段：访客端是否显示消息状态（送达/已读等） -->
    <changeSet id="260204-add-show-message-status" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <not>
                <columnExists tableName="bytedesk_kbase_service_settings" columnName="show_message_status" />
            </not>
        </preConditions>
        <comment>Add show_message_status field to control whether message status (delivered/read) is shown on visitor side.</comment>
        <addColumn tableName="bytedesk_kbase_service_settings">
            <column name="show_message_status" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="true" />
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="bytedesk_kbase_service_settings" columnName="show_message_status" />
        </rollback>
    </changeSet>

    <!-- 回填默认值（对于现有数据） -->
    <changeSet id="260204-backfill-show-message-status" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="show_message_status" />
        </preConditions>
        <comment>Backfill default value for existing rows.</comment>
        <sql>
            UPDATE bytedesk_kbase_service_settings
            SET show_message_status = true
            WHERE show_message_status IS NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
