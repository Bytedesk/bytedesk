    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="260310-add-shop-industry" author="copilot">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="bytedesk_core_shop"/>
                <not><columnExists tableName="bytedesk_core_shop" columnName="industry"/></not>
            </and>
        </preConditions>
        <addColumn tableName="bytedesk_core_shop">
            <column name="industry" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

