    <!-- speech_input: rename old column to prefixed one, or add if missing -->
    <changeSet id="260227-rename-toolbar-speech-input" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="speech_input" />
            <not>
                <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_speech_input" />
            </not>
        </preConditions>
        <renameColumn tableName="bytedesk_kbase_service_settings" oldColumnName="speech_input" newColumnName="toolbar_speech_input" columnDataType="BOOLEAN"/>
    </changeSet>

    <changeSet id="260227-add-toolbar-speech-input" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <not>
                <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_speech_input" />
            </not>
        </preConditions>
        <comment>Add toolbar_speech_input field to control speech-to-text input button visibility.</comment>
        <addColumn tableName="bytedesk_kbase_service_settings">
            <column name="toolbar_speech_input" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="true" />
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="260227-backfill-toolbar-speech-input" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_speech_input" />
        </preConditions>
        <comment>Backfill default value for existing rows.</comment>
        <sql>
            UPDATE bytedesk_kbase_service_settings
            SET toolbar_speech_input = true
            WHERE toolbar_speech_input IS NULL;
        </sql>
    </changeSet>

    <!-- webrtc: merge old audio/video switches into single toolbar_webrtc -->
    <changeSet id="260227-add-toolbar-webrtc" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <not>
                <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_webrtc" />
            </not>
        </preConditions>
        <comment>Add toolbar_webrtc field to control merged audio/video call button visibility.</comment>
        <addColumn tableName="bytedesk_kbase_service_settings">
            <column name="toolbar_webrtc" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="true" />
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="260227-backfill-toolbar-webrtc" author="githubcopilot">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_webrtc" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_audio" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_video" />
        </preConditions>
        <comment>Backfill toolbar_webrtc from toolbar_audio/toolbar_video when available.</comment>
        <sql>
            UPDATE bytedesk_kbase_service_settings
            SET toolbar_webrtc = (COALESCE(toolbar_audio, false) OR COALESCE(toolbar_video, false))
            WHERE toolbar_webrtc IS NULL;
        </sql>
    </changeSet>

    <changeSet id="260227-backfill-toolbar-webrtc-default" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_webrtc" />
        </preConditions>
        <comment>Default toolbar_webrtc to true for any remaining null rows.</comment>
        <sql>
            UPDATE bytedesk_kbase_service_settings
            SET toolbar_webrtc = true
            WHERE toolbar_webrtc IS NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
