    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Rename legacy toolbar columns to toolbar_* prefix -->

    <changeSet id="260227-rename-toolbar-smile" author="githubcopilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bytedesk_kbase_service_settings" />
            <columnExists tableName="bytedesk_kbase_service_settings" columnName="smile" />
            <not>
                <columnExists tableName="bytedesk_kbase_service_settings" columnName="toolbar_smile" />
            </not>
        </preConditions>
        <renameColumn tableName="bytedesk_kbase_service_settings" oldColumnName="smile" newColumnName="toolbar_smile" columnDataType="BOOLEAN"/>
    </changeSet>

